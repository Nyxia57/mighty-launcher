{
  "name": "mighty-launcher",
  "version": "1.1.0",
  "description": "Mighty Launcher — Minecraft Launcher with Modrinth API & Microsoft Auth",
  "author": "Mighty",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.mighty.launcher",
    "productName": "Mighty",
    "files": [
      "src/**/*",
      "main.js",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "Nyxia57",
      "repo": "mighty-launcher",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "forceCodeSigning": false
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mighty"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "41.0.3",
    "electron-builder": "^26.8.1"
  }
}